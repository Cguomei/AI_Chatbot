# 配置文件

# AI 模型配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama 本地模型配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen:7b  # 替换为你下载的模型名称，如：llama2、qwen、gemma 等
USE_OLLAMA=false  # 设置为 true 以使用 Ollama 本地模型

# 备用模型（通义千问）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 系统配置
BOT_NAME="小智客服"
MAX_CONTEXT_LENGTH=10  # 最大上下文轮数
TEMPERATURE=0.7  # 模型温度（0-1，越高越随机）

# 业务配置
SHOP_NAME="智能电商商城"
CUSTOMER_SERVICE_PHONE="400-123-4567"
WORKING_HOURS="9:00-22:00"
